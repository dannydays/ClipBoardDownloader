<Window x:Class="CBDownloader.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CB Downloader" Width="450" SizeToContent="Height"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Icon="/Assets/icon.png"
        Topmost="True">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding VideoTitle}" FontWeight="Bold" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,10"/>

        <Image Grid.Row="2" Source="{Binding VideoThumbnailUrl}" MaxHeight="120" Margin="0,0,0,10" Stretch="Uniform" />

        <StackPanel Grid.Row="3" Margin="0,10,0,10">
            <ProgressBar Value="{Binding DownloadProgress}" Maximum="100" Height="20" Margin="0,0,0,5" />
            <TextBlock Text="{Binding DownloadStatus}" FontSize="12" Foreground="#555"/>
        </StackPanel>

        <UniformGrid Grid.Row="5" Rows="1" Columns="3">
            <Button Content="Video" Height="35" Margin="0,0,5,0"
                    Command="{Binding DownloadVideoCommand}" />
            <Button Content="Audio" Height="35" Margin="5,0,5,0"
                    Command="{Binding DownloadAudioCommand}" />
            <Button Content="Exit" Height="35" Margin="5,0,0,0"
                    Command="{Binding ExitCommand}"/>
        </UniformGrid>
    </Grid>
</Window>
