<Window x:Class="CBDownloader.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CBDownloader" Width="500" Height="600"
        MinWidth="400" MinHeight="400"
        ResizeMode="CanResizeWithGrip" WindowStartupLocation="CenterScreen"
        Icon="/Assets/icon.ico"
        Background="{DynamicResource WindowBackgroundBrush}">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding VideoTitle}" FontWeight="Bold" FontSize="14" TextWrapping="Wrap" VerticalAlignment="Center" Foreground="{DynamicResource WindowForegroundBrush}"/>
            <Button Grid.Column="1" Content="⚙️ Settings" ToolTip="Open Settings" Padding="5,0" Height="25" Command="{Binding OpenSettingsCommand}"/>
        </Grid>
        
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Source="{Binding VideoThumbnailUrl}" Width="150" MaxHeight="100" Stretch="Uniform" Margin="0,0,10,0"/>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <Button Content="Queue Video" Height="35" Margin="0,0,0,10" Command="{Binding DownloadVideoCommand}" />
                <Button Content="Queue Audio" Height="35" Command="{Binding DownloadAudioCommand}" />
            </StackPanel>
        </Grid>

        <ListView Grid.Row="2" ItemsSource="{Binding Downloads}" Margin="0,10,0,10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Background="Transparent">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Thumbnail and Overlay Button -->
                        <Grid Grid.Column="0" Margin="0,0,10,0" Width="60" Height="40">
                            <Image Source="{Binding VideoThumbnailUrl}" Stretch="UniformToFill"/>
                            <Button ToolTip="Open Folder" 
                                    Command="{Binding OpenFolderCommand}"
                                    Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVis}}"
                                    Background="{DynamicResource ThumbnailOverlayBrush}" Foreground="White" BorderThickness="0"
                                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                <TextBlock Text="📁" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Button>
                        </Grid>
                        
                        <!-- TEXTBLOCK CONSTRAINED GRID -->
                        <Grid Grid.Column="1" VerticalAlignment="Center" Margin="0,0,10,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{Binding VideoTitle}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource WindowForegroundBrush}"/>
                            <ProgressBar Grid.Row="1" Value="{Binding DownloadProgress}" Maximum="100" Height="5" Margin="0,5,0,2" Background="{DynamicResource ProgressBarBackgroundBrush}"/>
                            <TextBlock Grid.Row="2" Text="{Binding DownloadStatus}" FontSize="10" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                        </Grid>
                        
                        <!-- BUTTONS -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0">
                            <!-- Retry Video -->
                            <Button Content="↻ Video" Padding="5,2" Margin="0,0,5,0"
                                    Command="{Binding RetryVideoCommand}" 
                                    Visibility="{Binding ShowRetry, Converter={StaticResource BoolToVis}}"/>
                            <!-- Retry Audio -->
                            <Button Content="↻ Audio" Padding="5,2" Margin="0,0,5,0"
                                    Command="{Binding RetryAudioCommand}" 
                                    Visibility="{Binding ShowRetry, Converter={StaticResource BoolToVis}}"/>
                            <!-- Cancel -->
                            <Button Content="✕" Width="25" Height="25" Padding="0" Margin="0,0,0,0"
                                    Command="{Binding CancelCommand}" 
                                    Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Hide Window (Keep running in background)" Height="35" Margin="0,0,5,0" Command="{Binding ExitCommand}"/>
            <Button Grid.Column="1" Content="🧹 Clear List" ToolTip="Clear Completed/Error Downloads" Height="35" Padding="15,0" Command="{Binding ClearCompletedCommand}"/>
        </Grid>
    </Grid>
</Window>
