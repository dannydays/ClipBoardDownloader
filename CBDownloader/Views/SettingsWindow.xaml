<Window x:Class="CBDownloader.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" SizeToContent="Height" MinHeight="250" Width="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="/Assets/icon.ico"
        Topmost="True">
    <StackPanel Margin="20">
        <TextBlock Text="Settings" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
        <CheckBox Content="Start with Windows" IsChecked="{Binding StartWithWindows}" Margin="0,0,0,15"/>
        
        <TextBlock Text="Updates" FontSize="14" FontWeight="Bold" Margin="0,10,0,5"/>
        <TextBlock Text="{Binding CurrentVersion, StringFormat='Current Version: {0}'}" Margin="0,0,0,5" Foreground="Gray"/>
        <Button Content="Check for Updates" Command="{Binding CheckForUpdatesCommand}" Height="30" Margin="0,0,0,10"/>
        <TextBlock Text="{Binding UpdateStatus}" TextWrapping="Wrap" Foreground="#555"/>
    </StackPanel>
</Window>
