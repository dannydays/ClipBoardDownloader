<Window x:Class="CBDownloader.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Width="380" Height="520"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Icon="/Assets/icon.ico" Topmost="True"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="15">
        <StackPanel>
            <TextBlock Text="Settings" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Foreground="{DynamicResource WindowForegroundBrush}"/>

            <TextBlock Text="Theme" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource WindowForegroundBrush}"/>
            <ComboBox ItemsSource="{Binding AvailableThemes}" SelectedItem="{Binding AppTheme}" Height="30" Margin="0,0,0,15"/>

            <TextBlock Text="Downloads Location" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource WindowForegroundBrush}"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding DownloadFolderPath}" Height="30" VerticalContentAlignment="Center" IsReadOnly="True" />
                <Button Grid.Column="1" Content="..." Width="35" Height="30" Margin="5,0,0,0" Command="{Binding BrowseFolderCommand}"/>
            </Grid>

            <CheckBox IsChecked="{Binding StartWithWindows}" Content="Start with Windows" Margin="0,0,0,10" VerticalContentAlignment="Center"/>
            <CheckBox IsChecked="{Binding AlwaysOnTop}" Content="Keep on top of other windows" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Instagram Support" FontWeight="Bold" Margin="0,0,0,10" Foreground="{DynamicResource WindowForegroundBrush}"/>
                    <CheckBox IsChecked="{Binding UseBrowserCookies}" Content="Use browser cookies (for private links)" Margin="0,0,0,10" VerticalContentAlignment="Center"/>
                    
                    <TextBlock Text="Read cookies from:" Margin="0,0,0,5" FontSize="11" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                    <ComboBox ItemsSource="{Binding AvailableBrowsers}" SelectedItem="{Binding BrowserForCookies}" IsEnabled="{Binding UseBrowserCookies}" Height="25"/>
                </StackPanel>
            </Border>

            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding CurrentVersion}" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12"/>
                    <TextBlock Text="{Binding UpdateStatus}" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="10" TextWrapping="Wrap"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Update" Padding="15,5" Command="{Binding CheckForUpdatesCommand}"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
